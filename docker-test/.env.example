# NR EnrichCore — test environment variables
# Copy to docker-test/.env and fill in as needed.
# These override the defaults in docker-compose.yml.

# Bundle source directory (absolute or relative to repo root)
BUNDLE_SRC=.

# Docker test stack database settings consumed by docker-test/docker-compose.yml
TEST_DB_PORT=3307
TEST_DB_NAME=nrec_test
TEST_DB_USER=nrec
TEST_DB_PASSWORD=nrec
TEST_DB_ROOT_PASSWORD=root

# The php service inside Docker derives DB_HOST/DB_PORT/DB_* from TEST_DB_*.
# If you run tests outside Docker, export DB_HOST/DB_PORT/DB_NAME/DB_USER/DB_PASSWORD separately.

# Pimcore / Symfony
APP_ENV=test
APP_DEBUG=0

# Set to 'coverage' when running bin/run-tests.sh --coverage
XDEBUG_MODE=off
